sticky yes
snapdist 8
gap 26 8 8 8
moveamount 10
borderwidth 2
fontname "Tamzen:pixelsize=16:antialias=true"

ignore xclock
ignore bar

autogroup 0 bar
autogroup 0 xclock

color menubg "#0b0d0d"
color menufg "#99ccbf"
color urgencyborder "#e6a1a1"
color groupborder "#a1c8e6"
color ungroupborder "#e8c2a2"
color inactiveborder "#192626"
color activeborder "#99ccbf"
color font "#99ccbf"

unbind-key all

bind-key 4-Return "urxvt"
bind-key 4-b "firefox"
bind-key 4-q window-close
bind-key 4S-q quit
bind-key 4S-e lock
bind-key 4S-r restart
bind-key 4-d "dmenu_run -nb '#0b0d0d' -nf '#99ccbf' -sb '#99ccbf' -sf '#0b0d0d' -fn 'Tamzen:style=regular:pixelsize=16'"
bind-key 4-m window-fullscreen
bind-key 4-n window-maximize
bind-key 4-w window-vtile
bind-key 4S-Tab window-cycle
bind-key 4-Tab group-cycle

